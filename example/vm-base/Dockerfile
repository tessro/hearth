# hearth/vm-base — the boilerplate every bootable Hearth VM image repeats.
#
# Build it once as a plain local buildah image, then base workload images on it:
#
#   buildah bud --layers -t vm-base -f example/vm-base/Dockerfile example/vm-base
#   #   ...then, in a workload Dockerfile:  FROM localhost/vm-base
#
# Everything here was learned the hard way during the 2026-07 Hermes bring-up:
# each line prevents a boot failure that cost a full build+boot cycle (~10 min)
# to diagnose from the serial console. See REFACTOR_PROPOSAL.md §2.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Boot + install-time essentials. --no-install-recommends keeps the image lean,
# but that means every dependency the boot path needs is explicit:
#   systemd, systemd-sysv  — PID 1 and /sbin/init.
#   udev                   — without it the NIC is never initialized and stays
#                            `pending` forever (inventory #4).
#   dbus                   — the system bus: networkd/logind IPC, and the bus
#                            `systemctl --user`/`loginctl` reach logind through.
#   dbus-user-session      — the per-user session bus units (/usr/lib/systemd/
#                            user/dbus.socket|service). Without them the agent's
#                            session bus never listens and every `systemctl
#                            --user`/`busctl --user` fails "Failed to connect to
#                            bus" — the exact gap the field report hit.
#   libpam-systemd         — pam_systemd.so, auto-wired into common-session by the
#                            package's pam-auth-update trigger: an SSH login then
#                            registers a logind session and gets XDG_RUNTIME_DIR
#                            (/run/user/1000) + a user manager. Absent, `loginctl`
#                            sees no session and $XDG_RUNTIME_DIR is unset.
#   iproute2, util-linux   — ip/networkctl, mount/findmnt/growfs, runuser helpers.
#   openssh-server         — post-boot login; host keys are (re)generated by the
#                            ssh-hostkeys unit below, not baked in.
#   ca-certificates, curl  — TLS + the workload installers layered on top.
#   xz-utils               — the Hermes installer dies mid-build without it
#                            (inventory, a full boot cycle lost).
#   procps, sudo           — probes and the passwordless `agent` shell.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    dbus \
    dbus-user-session \
    iproute2 \
    libpam-systemd \
    openssh-server \
    procps \
    sudo \
    systemd \
    systemd-sysv \
    udev \
    util-linux \
    xz-utils \
  # openssh-server's postinst runs `ssh-keygen -A`, baking identical host keys
  # into this shared image. Remove them so ssh-hostkeys.service (guarded on
  # ConditionPathExists=!.../ssh_host_ed25519_key) regenerates a UNIQUE set on
  # each spawned VM's first boot — otherwise every VM presents the same
  # fingerprints (README's per-VM host-key promise, §3).
  && rm -f /etc/ssh/ssh_host_* \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# The unprivileged workload user, pinned to UID/GID 1000 so §3 provisioning can
# `owner = "1000:1000"` files into /home/agent without resolving names. Ubuntu
# 24.04 ships a default `ubuntu` user at 1000, so remove it first or agent lands
# on 1001 and provisioned files end up owned by the wrong user.
RUN userdel --remove ubuntu 2>/dev/null || true \
  && groupadd --gid 1000 agent \
  && useradd --create-home --shell /bin/bash --uid 1000 --gid 1000 agent \
  && install -d -m 0755 /etc/sudoers.d \
  && printf '%s\n' 'agent ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/agent \
  && chmod 0440 /etc/sudoers.d/agent

# DHCP on the first ethernet NIC, the /usr/local/bin/init mount shim (mounts the
# pseudo-filesystems + pins the hearth0 resolver), and the host-key regen unit.
COPY 20-dhcp.network /etc/systemd/network/20-dhcp.network
COPY ssh-hostkeys.service /etc/systemd/system/ssh-hostkeys.service
COPY hearth-usersession.service /etc/systemd/system/hearth-usersession.service
COPY hearth-usersession-check /usr/local/bin/hearth-usersession-check
COPY init /usr/local/bin/init

RUN chmod 0755 /usr/local/bin/init /usr/local/bin/hearth-usersession-check \
  && mkdir -p /etc/systemd/system/multi-user.target.wants \
              /etc/systemd/system/sysinit.target.wants \
              /etc/systemd/system/sockets.target.wants \
              /run/sshd \
  # udev: the exact unit + socket symlinks that make the NIC initialize.
  && ln -sf /lib/systemd/system/systemd-udevd.service /etc/systemd/system/sysinit.target.wants/systemd-udevd.service \
  && ln -sf /lib/systemd/system/systemd-udev-trigger.service /etc/systemd/system/sysinit.target.wants/systemd-udev-trigger.service \
  && ln -sf /lib/systemd/system/systemd-udevd-control.socket /etc/systemd/system/sockets.target.wants/systemd-udevd-control.socket \
  && ln -sf /lib/systemd/system/systemd-udevd-kernel.socket /etc/systemd/system/sockets.target.wants/systemd-udevd-kernel.socket \
  # networkd + sshd + host-key regen enabled at multi-user.
  && ln -sf /lib/systemd/system/systemd-networkd.service /etc/systemd/system/multi-user.target.wants/systemd-networkd.service \
  && ln -sf /lib/systemd/system/ssh.service /etc/systemd/system/multi-user.target.wants/ssh.service \
  && ln -sf /etc/systemd/system/ssh-hostkeys.service /etc/systemd/system/multi-user.target.wants/ssh-hostkeys.service \
  # system bus + logind at boot. Both are normally socket-/dbus-activated, but a
  # --no-install-recommends image runs no systemctl preset, so wire them by hand
  # like everything else here: without dbus.socket the session bus and `systemctl
  # --user` have nothing to reach; without systemd-logind there is no
  # XDG_RUNTIME_DIR and no user@ manager — the session infrastructure the field
  # report found missing.
  && ln -sf /lib/systemd/system/dbus.socket /etc/systemd/system/sockets.target.wants/dbus.socket \
  && ln -sf /lib/systemd/system/dbus.service /etc/systemd/system/multi-user.target.wants/dbus.service \
  && ln -sf /lib/systemd/system/systemd-logind.service /etc/systemd/system/multi-user.target.wants/systemd-logind.service \
  # Boot-time proof the agent user's session stack is live (one marker on serial).
  && ln -sf /etc/systemd/system/hearth-usersession.service /etc/systemd/system/multi-user.target.wants/hearth-usersession.service \
  # Lingering: start user@1000.service at boot with NO login, so the agent's user
  # manager and its delegated cgroup subtree exist before the first SSH session.
  # Ubuntu 24.04's systemd 255 ships `Delegate=pids memory cpu` on user@.service
  # (verified against the installed unit) — that delegation is precisely the
  # "cgroup delegation" the field report said this environment lacked.
  && install -d /var/lib/systemd/linger \
  && touch /var/lib/systemd/linger/agent \
  # serial-getty on ttyS0 masked: it races the kernel console and hangs boot 90s.
  && ln -sf /dev/null /etc/systemd/system/serial-getty@ttyS0.service \
  # Root fs entry with x-systemd.growfs so the disk expands to the created size.
  && printf '%s\n' '/dev/vda / ext4 defaults,x-systemd.growfs 0 1' > /etc/fstab

# `hearthctl stop` shuts down cleanly because the guest handles the ACPI power
# event Cloud Hypervisor raises (kernel ACPI + systemd) — NOT because of OCI
# STOPSIGNAL, which Hearth boots the image as a VM and never sends. STOPSIGNAL is
# kept only as metadata for anyone running this image under docker/podman.
STOPSIGNAL SIGRTMIN+3
CMD ["/usr/local/bin/init"]
