# Copy this file to hermes.env (gitignored) and fill it in. It becomes
# /home/agent/.hermes/.env inside the VM, which Hermes loads automatically.
#
# These values are NOT baked into the image anymore. §3/§10 provision this file
# into each VM at create time (`spawn --provision-file source=./hermes.env,\
# dest=/home/agent/.hermes/.env,mode=0600,owner=1000:1000`, or a [provision]
# entry in the service TOML), so two VMs from one image get independent
# credentials instead of a shared, world-readable-to-root copy in the image.

# Required: `hermes serve` refuses unauthenticated non-loopback access, and the
# macOS app signs in with these.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-me
# Stable signing key so desktop-app sessions survive VM restarts.
# Generate with: openssl rand -hex 32
HERMES_DASHBOARD_BASIC_AUTH_SECRET=change-me-too

# Model provider credentials — set at least one, or run `hermes setup` over
# ssh after first boot (e.g. `hermes setup --portal` for Nous Portal OAuth).
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
