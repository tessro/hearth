# Hearth guest kernel contract (kernel contract 1).
#
# This is a Kconfig *fragment*, not a full .config. scripts/build-guest-kernel.sh
# merges it over `make defconfig` with scripts/kconfig/merge_config.sh and then
# runs `make olddefconfig`, so defconfig supplies the x86_64 base (SMP, printk,
# ELF binfmt, proc/sysfs, seccomp, namespaces, INET/IPv6) and this file pins the
# VM contract on top. Everything the guest depends on at runtime is =y (built
# in, never =m): there is no initramfs and the guest rootfs has no matching
# /lib/modules, so a driver that is a module is a driver that does not exist.
#
# Every group below is commented with the concrete boot/runtime failure it
# prevents (mirrors the workaround inventory in REFACTOR_PROPOSAL.md). Bump the
# contract number in build-guest-kernel.sh whenever this file gains a feature an
# image can require via `min_kernel_contract`.

# --- PVH direct boot (MANDATORY) ------------------------------------------
# Cloud Hypervisor direct-boots a raw `vmlinux` ELF through the x86 PVH entry
# point; without CONFIG_PVH the ELF carries no PVH note and CHV refuses to boot
# it ("Error booting VM ... Load Kernel"). This is the single option that makes
# the no-bootloader, no-bzImage, no-initramfs boot path possible.
CONFIG_PVH=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y
CONFIG_JUMP_LABEL=y

# --- virtio transport + block + net ---------------------------------------
# The host kernel shipped these as =m and the guest had no modules to load them
# from: root=/dev/vda then panics with "Unable to mount root fs" (virtio_blk),
# and the NIC never appears (virtio_net). Built in, they are present before
# root is opened.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
# A zero-sized virtio balloon with free-page reporting lets the guest tell
# Cloud Hypervisor which previously-used pages are free, so the VMM can return
# them to the host without reducing guest-visible RAM.
CONFIG_VIRTIO_BALLOON=y
CONFIG_PAGE_REPORTING=y
CONFIG_PCI=y

# --- vsock (Hearth control channel) ---------------------------------------
# hearthd talks to the guest over an AF_VSOCK socket (CHV --vsock). Missing
# support silently drops the daemon's in-guest control/health channel.
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# --- root filesystem (ext4) -----------------------------------------------
# The per-VM root disk is a bare whole-device ext4 image. Without EXT4 built in,
# root=/dev/vda cannot be mounted and the boot panics before init runs.
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# --- af_packet (systemd-networkd DHCPv4) ----------------------------------
# systemd-networkd's DHCPv4 client opens an AF_PACKET raw socket. This was the
# last module discovered by boot-iteration: without it networkd stays at
# "configuring" forever and the VM never gets a lease/default route.
CONFIG_PACKET=y

# --- console / serial -----------------------------------------------------
# CHV wires the guest console to ttyS0 (--serial file=...). Without the 8250
# UART + console, there is no serial log at all and every boot failure is blind.
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y
CONFIG_PRINTK=y

# --- devtmpfs / tmpfs (systemd + udev) ------------------------------------
# systemd mounts /dev from devtmpfs and needs the kernel to auto-mount it early;
# udev populates device nodes from it. tmpfs backs /run, /tmp, /dev/shm. Missing
# these, systemd fails to reach basic.target.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_AUTOFS_FS=y

# --- virtiofs / FUSE (shared host directories) ----------------------------
# Optional host<->guest directory sharing rides virtio-fs, which is a FUSE
# client. Built in so a virtiofsd-backed mount works without a module.
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# --- overlayfs (Docker overlay2 storage driver) ---------------------------
# Docker inside the guest defaults to the overlay2 storage driver; without
# OVERLAY_FS it falls back to vfs (or fails), which cost a full boot cycle to
# diagnose from the daemon log.
CONFIG_OVERLAY_FS=y

# --- cgroup v2 (systemd unified hierarchy + Docker) -----------------------
# systemd's unified hierarchy and Docker's resource limits both require the
# cgroup v2 controllers. Missing controllers surface as opaque systemd/Docker
# startup errors rather than a clean message.
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_USER_NS=y

# --- bridge + veth + netfilter (Docker-in-guest networking) ---------------
# Docker's default bridge network needs a Linux bridge, veth pairs, bridge
# netfilter, and the nat/conntrack/iptables(+nft) stack to publish and
# masquerade container traffic. The plan doc (docs/dockerfile-vm-plan.md) calls
# out "namespaces and netfilter features needed by Docker inside the guest";
# this is that set, built in so `docker run -p` works on first boot.
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_LLC=y
CONFIG_STP=y
CONFIG_VETH=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_NETLINK=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_COMPAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP_VS=y

# --- module signing off ---------------------------------------------------
# The guest boots a self-contained vmlinux with no out-of-tree modules; module
# signing would only add an openssl key-generation build dependency for nothing.
# CONFIG_MODULE_SIG is not set
